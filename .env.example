NODE_ENV=development
PORT=3000
LOG_FORMAT=dev

DB_PORT=5432

# WITH DOCKER (make setup / make up):
#   DB_HOST must be "database" — that is the service name in docker-compose.yml.
#   Docker Compose overrides this automatically, so you can leave it as
#   "localhost" here and it will still work inside the container. But setting
#   it to "database" avoids confusion when reading the file.
#   DB_HOST=database
DB_HOST=database

# With Docker: this database is auto-created by the postgres container on first boot.
# Without Docker: you must create it manually → run: createdb easecommerce
DB_NAME=easecommerce

# With Docker: "postgres" is the default superuser created by the postgres image.
# Without Docker: use whatever user exists on your local Postgres installation.
DB_USER=postgres

# With Docker: this must match POSTGRES_PASSWORD in docker-compose.yml.
#   The docker-compose.yml reads it from this same .env file, so just set one value here.
# Without Docker: use the password you set when you installed/configured PostgreSQL locally.
DB_PASSWORD=yourpassword


# UrbaneBolt UAT credentials
URBANEBOLT_BASE_URL=https://uat.urbanebolt.in
URBANEBOLT_USERNAME=info@urbanebolt.co
URBANEBOLT_PASSWORD=EKIcygsLVV5RCtPZGJGGHH000
URBANEBOLT_CUSTOMER_CODE=UEBCUS000YH9988A8
URBANEBOLT_TIMEOUT=10000
URBANEBOLT_MAX_RETRIES=3
URBANEBOLT_RETRY_DELAY=1000

# ─────────────────────────────────────────────────────────────────────────────
# Bulk processing
# Max number of concurrent courier API calls when processing a bulk order batch.
# ─────────────────────────────────────────────────────────────────────────────
BULK_CONCURRENCY=10
