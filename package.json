{
  "name": "multi-courier-platform",
  "version": "1.0.0",
  "description": "Unified backend API for multi-courier shipment integration",
  "main": "index.js",
  "author": {
    "name": "Shubham Gupta",
    "email": "shubhamgupta9891@gmail.com"
  },
  "scripts": {
    "start": "node index.js",
    "dev": "node --watch index.js",
    "db:migrate": "npx sequelize-cli db:migrate",
    "db:migrate:undo": "npx sequelize-cli db:migrate:undo:all",
    "db:seed": "npx sequelize-cli db:seed:all",
    "db:reset": "npm run db:migrate:undo && npm run db:migrate && npm run db:seed"
  },
  "dependencies": {
    "axios": "1.18.1",
    "axios-retry": "4.5.0",
    "cors": "2.8.6",
    "dotenv": "16.4.5",
    "express": "4.19.2",
    "helmet": "8.2.0",
    "joi": "17.13.3",
    "morgan": "1.10.0",
    "p-limit": "3.1.0",
    "pg": "8.22.0",
    "pg-hstore": "2.3.4",
    "sequelize": "6.37.8",
    "swagger-jsdoc": "6.2.8",
    "swagger-ui-express": "5.0.1",
    "uuid": "14.0.1"
  },
  "devDependencies": {
    "sequelize-cli": "6.6.5"
  }
}
